# Скопируйте этот файл в .env и заполните значения.
# Copy this file to .env and fill in the values.

# Секретный ключ для подписи сессий (любая длинная случайная строка).
# Secret key for session signing (any long random string).
SECRET_KEY=change-me-to-a-long-random-string

# Путь к базе данных SQLite. / Path to the SQLite database.
DATABASE_URL=sqlite:///./project_board.db

# За сколько дней до дедлайна напоминать (через запятую можно несколько).
# How many days before a deadline to send a reminder (comma-separated for several).
REMINDER_DAYS_BEFORE=7,3,1

# Время ежедневной проверки дедлайнов, часы:минуты по серверному времени.
# Daily deadline-check time, HH:MM in server time.
DAILY_CHECK_TIME=09:00

# --- Telegram ---
# Токен бота от @BotFather. / Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
